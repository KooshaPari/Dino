{
  "mcpServers": {
    "dinoforge": {
      "command": "python",
      "args": ["-m", "dinoforge_mcp.server"],
      "cwd": "src/Tools/DinoforgeMcp",
      "env": {
        "DINOFORGE_CLI_PATH": "src/Tools/Cli",
        "DINOFORGE_PIPE_NAME": "dinoforge_game",
        "DINOFORGE_MCP_DEBUG": "false"
      },
      "description": "DINOForge game automation - query entities, UI automation, spawn units, apply overrides, asset pipeline"
    }
  }
}
