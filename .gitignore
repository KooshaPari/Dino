# Asset downloads and cache
# Note: Downloaded model.glb files in packs/*/assets/raw/*/model.glb ARE committed for asset pipeline
# Build-generated assets in other locations are not tracked
*.glb
*.gltf
*.blend
*.fbx
*.obj
*.usdz
packs/*/assets/raw/**/source_download.*
!packs/*/assets/raw/*/model.glb
.cache/
.cache/sketchfab/
.fixtures/
.env.local

# Pipeline/debug artifacts
import_output.log
phase3a_runner.csx
tmp_*.png
.factory/
